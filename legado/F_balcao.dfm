  object qryProd: TIBQuery
    Database = DM1.DATA2
    Transaction = DM1.TRANS2
    BufferChunks = 1000
    CachedUpdates = False
    ParamCheck = True
    SQL.Strings = (
      'select'
      
        '  P1.ID, P1.CODIGOBARRA, P2.QUANTIDADE, P3.DESCRICAO, P3.UN_MEDI' +
        'DA,'
      '  P4.PRECOCUSTO, P4.PRECOVENDA, P4.ATACADO,'
      
        '  P3.CST_ORIGEM, P3.CST, P3.CSOSN, P3.ICMS, P3.ICMS_ST,P3.ncm,P3' +
        '.cest,P3.cfop,'
      ' P3.CST_PIS, P3.ALIQ_PIS, P3.CST_COFINS, P3.ALIQ_COFINS'
      
        'from PRODUTO P1, PRODUTOEMPRESA P2, PRODUTOESERVICO P3, PRODUTOE' +
        'SERVICOEMPRESA P4'
      'where'
      '   P1.ID = P2.ID and   P1.ID = P3.ID and   P1.ID = P4.ID'
      ' and'
      
        '  ( P3.ID = :CODIGO_PRODUTO OR P1.CODIGOBARRA=:CODIGO_PRODUTO OR' +
        ' P3.CODIGOINTERNO=:CODIGO_PRODUTO)'
      '       '
      '     ')
    PrecommittedReads = False
    Left = 83
    Top = 396
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'CODIGO_PRODUTO'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'CODIGO_PRODUTO'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'CODIGO_PRODUTO'
        ParamType = ptUnknown
      end>
