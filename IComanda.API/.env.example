# ========================================
# iComanda - Variáveis de Ambiente
# ========================================
#
# INSTRUÇÕES:
# 1. Copie este arquivo para .env
# 2. Preencha com os valores reais
# 3. NUNCA commite o arquivo .env no Git
#
# ========================================

# ========================================
# BANCO DE DADOS
# ========================================
FIREBIRD_SERVER=localhost
FIREBIRD_PORT=3050
FIREBIRD_DATABASE=C:\iComanda\Dados\DADOSG5.FDB
FIREBIRD_USER=SYSDBA
FIREBIRD_PASSWORD=masterkey

# Connection String completa (alternativa)
# ConnectionStrings__Firebird=Server=localhost;Database=C:\iComanda\Dados\DADOSG5.FDB;User=SYSDBA;Password=masterkey;Port=3050;

# ========================================
# JWT (JSON Web Token)
# ========================================
# IMPORTANTE: Gere uma chave forte usando:
# openssl rand -base64 32
# ou online em: https://generate-secret.vercel.app/32
JWT_SECRET_KEY=SUBSTITUA_POR_UMA_CHAVE_FORTE_MINIMO_32_CARACTERES
JWT_ISSUER=IComanda.API
JWT_AUDIENCE=IComanda.Client
JWT_EXPIRATION_HOURS=2
JWT_REFRESH_EXPIRATION_DAYS=7

# ========================================
# SERVIDOR
# ========================================
ASPNETCORE_ENVIRONMENT=Production
KESTREL_PORT=65375
ASPNETCORE_URLS=http://0.0.0.0:65375

# ========================================
# REDIS CACHE (Opcional - para produção)
# ========================================
# REDIS_CONNECTION=localhost:6379
# REDIS_PASSWORD=

# ========================================
# IMPRESSÃO
# ========================================
IMPRESSORA_TIPO=Rede
IMPRESSORA_IP=192.168.0.150
IMPRESSORA_PORTA=9100
IMPRESSORA_NOME=MP-2500 TH
IMPRESSORA_LARGURA=80

# ========================================
# EMPRESA
# ========================================
EMPRESA_NOME=SUA EMPRESA LTDA
EMPRESA_NOME_FANTASIA=Nome Fantasia
EMPRESA_CNPJ=00.000.000/0001-00
EMPRESA_ENDERECO=Rua Exemplo, 123
EMPRESA_BAIRRO=Centro
EMPRESA_CIDADE=Cidade - UF
EMPRESA_CEP=00000-000
EMPRESA_TELEFONE=(00) 0000-0000

# ========================================
# WHATSAPP
# ========================================
WHATSAPP_METODO=link
# Opções: link, baileys, selenium, evolution

# ========================================
# RATE LIMITING
# ========================================
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=Information
# Opções: Trace, Debug, Information, Warning, Error, Critical
